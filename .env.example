# ===== Tracker: Gitea (default) =====
# Gitea API token (create at Gitea → User Settings → Applications → Generate Token)
GITEA_TOKEN=your_gitea_token_here

# Gitea repository in "owner/repo" format
GITEA_PROJECT_SLUG=rockopera/myproject

# Gitea URL (inside docker network, backend connects to gitea container)
GITEA_URL=http://gitea:3000

# Gitea external port (for browser access)
GITEA_PORT=3001

# Gitea root URL (for links in the UI)
GITEA_ROOT_URL=http://localhost:3001

# Disable public registration after initial setup
GITEA_DISABLE_REGISTRATION=false

# ===== Tracker: Linear (alternative) =====
# Uncomment and set these if using Linear instead of Gitea
# LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LINEAR_PROJECT_SLUG=my-project
# LINEAR_ASSIGNEE=

# ===== Agent: Claude Code =====
# Optional timeout used by some Claude Code builds / provider bridges.
API_TIMEOUT_MS=3000000

# Backward-compatible single-profile vars.
# These remain the startup default when no LLM profile has been activated in the UI
# and no `agent.llm_profiles.default` is set in WORKFLOW.md.
ANTHROPIC_MODEL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=

# Predefined profile: GLM-5 via Anthropic-compatible endpoint
GLM_ANTHROPIC_AUTH_TOKEN=
GLM_ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
GLM_SONNET_MODEL=glm-5

# Predefined profiles: GPT-4.1 / o3 via LiteLLM.
# Start compose with: docker compose --profile llm-gateway up -d
# The existing gateway script maps:
#   rockopera-sonnet -> OPENAI_LIKE_SONNET_MODEL
#   rockopera-opus   -> OPENAI_LIKE_OPUS_MODEL
LITELLM_IMAGE=docker.litellm.ai/berriai/litellm:main-latest
LITELLM_MASTER_KEY=sk-rockopera-local
OPENAI_LIKE_API_BASE=
OPENAI_LIKE_API_KEY=
OPENAI_LIKE_SONNET_MODEL=openai/gpt-4.1
OPENAI_LIKE_OPUS_MODEL=openai/o3
OPENAI_LIKE_HAIKU_MODEL=openai/gpt-4.1-mini

# ===== General =====
# Assignee filter: "me" for API key owner, or specific username
TRACKER_ASSIGNEE=

# Polling interval in milliseconds (default: 30000)
POLL_INTERVAL_MS=30000

# Max concurrent agents (default: 10)
MAX_CONCURRENT_AGENTS=10

# Backend port (default: 4000)
BACKEND_PORT=4000

# Frontend port (default: 3000)
FRONTEND_PORT=3000
